#jinja2: trim_blocks: True, lstrip_blocks: True
# /etc/monitoring/monitor.env — управляется Ansible, не редактируйте вручную.
# Файл подключается всеми bash-скриптами через monitor_common.sh.

# --- Каталоги ---
MON_BASE_DIR="{{ mon_base_dir }}"
MON_LOG_DIR="{{ mon_log_dir }}"
MON_STATE_DIR="{{ mon_state_dir }}"
MON_CONFIG_DIR="{{ mon_config_dir }}"
MON_REPORT_DIR="{{ mon_report_dir }}"
MON_ARCHIVE_DIR="{{ mon_archive_dir }}"
MON_INCIDENT_LOG="{{ mon_incident_log }}"

# --- Сервер ---
SERVER_HOST="{{ mon_server_host }}"
SERVER_IP="{{ mon_server_ip }}"

# --- Сервисы (требование задания, п.1) ---
CRITICAL_SERVICES="{{ mon_services_critical | map(attribute='name') | join(',') }}"
OPTIONAL_SERVICES="{{ mon_services_optional | map(attribute='name') | join(',') }}"
SERVICE_PORT_MAP="{% for svc in mon_services %}{{ svc.name }}:{{ svc.port | default(0) }}:{{ svc.protocol | default('tcp') }}{% if not loop.last %},{% endif %}{% endfor %}"

# NextCloud URL для health-check (особый виртуальный сервис)
NEXTCLOUD_CHECK_URL="http://127.0.0.1/nextcloud/status.php"

# --- Пороги производительности (требование задания, п.4) ---
THRESHOLD_CPU="{{ mon_threshold_cpu }}"
THRESHOLD_CPU_DURATION_MIN="{{ mon_threshold_cpu_duration_min }}"
PERFORMANCE_INTERVAL_SEC="{{ mon_freq_performance }}"
THRESHOLD_RAM="{{ mon_threshold_ram }}"
THRESHOLD_DISK_WARNING_FREE="{{ mon_threshold_disk_warning_free }}"
THRESHOLD_DISK_CRITICAL_FREE="{{ mon_threshold_disk_critical_free }}"
THRESHOLD_INTERNET_MBPS="{{ mon_threshold_internet_mbps }}"
THRESHOLD_SWAP="{{ mon_threshold_swap }}"
THRESHOLD_INODE="{{ mon_threshold_inode }}"
THRESHOLD_LOAD1="{{ mon_threshold_load1 }}"
THRESHOLD_IOWAIT="{{ mon_threshold_iowait }}"
SPEEDTEST_URL="{{ mon_speedtest_url }}"

# --- Безопасность ---
SECURITY_FAILED_THRESHOLD="{{ mon_security_failed_threshold }}"
SECURITY_FAILED_WINDOW_MIN="{{ mon_security_failed_window_min }}"
SECURITY_BAN_SECONDS="{{ mon_security_ban_seconds }}"
ALLOWED_PORTS="{{ mon_allowed_ports | join(',') }}"

# --- Автореагирование ---
ALERT_AUTORESPONSE="{{ mon_autorespond | ternary('yes', 'no') }}"
RESTART_MAX_ATTEMPTS="{{ mon_restart_max_attempts }}"
ISOLATION_ENABLED="{{ mon_isolation_enabled | ternary('yes', 'no') }}"
ISOLATION_SECONDS="{{ mon_isolation_seconds }}"
ISOLATION_MODE="{{ mon_isolation_mode }}"
ISOLATION_NETWORK="{{ mon_classroom_network }}"
MANAGEMENT_IP="{{ mon_management_ip }}"

# --- Email ---
ALERT_FROM={{ mon_alert_from | to_json }}
ALERT_TO={{ mon_alert_to | to_json }}
ALERT_SUBJECT_PREFIX={{ mon_alert_subject_prefix | to_json }}
ALERT_THROTTLE_MIN="{{ mon_alert_throttle_min }}"
SMTP_HOST={{ mon_smtp_host | string | to_json }}
SMTP_PORT="{{ mon_smtp_port }}"
SMTP_USE_TLS="{{ mon_smtp_use_tls | ternary('yes', 'no') }}"
SMTP_REQUIRE_TLS_REPORTS="{{ mon_smtp_require_tls_for_reports | ternary('yes', 'no') }}"
SMTP_VERIFY_TLS="{{ mon_smtp_verify_tls | ternary('yes', 'no') }}"
SMTP_CA_FILE={{ mon_smtp_ca_file | to_json }}
{% if vault_smtp_user is defined and vault_smtp_user | length > 0 %}
SMTP_USER={{ vault_smtp_user | to_json }}
SMTP_PASSWORD={{ vault_smtp_password | to_json }}
{% endif %}

# --- Отчёты ---
REPORT_RETENTION_DAYS="{{ mon_report_retention_days }}"
REPORT_ARCHIVE_KEEP_MONTHS="{{ mon_report_archive_keep_months }}"
MAINTENANCE_SECURITY_ONLY="{{ mon_maintenance_security_only | ternary('yes', 'no') }}"
LOG_RETENTION_DAYS="{{ mon_log_retention_days }}"
